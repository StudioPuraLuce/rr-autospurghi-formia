---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
}

const { 
  title, 
  subtitle = "Soluzioni professionali per la tua zona.", 
  ctaText = "Richiedi Preventivo Gratis", 
  ctaLink = "#contatti" 
} = Astro.props;
---

<section class="relative bg-secondary py-24 px-6 overflow-hidden">
  <div class="max-w-7xl mx-auto flex flex-col items-center text-center relative z-10">
    <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight leading-tight mb-6">
      {title}
    </h1>
    <p class="text-lg md:text-xl text-gray-300 max-w-2xl mb-10 leading-relaxed">
      {subtitle}
    </p>
    <a href={ctaLink} class="inline-block bg-primary hover:bg-blue-600 text-white font-bold text-lg py-4 px-10 rounded-full transition-all transform hover:scale-105 shadow-xl">
      {ctaText}
    </a>
  </div>
  
  {/* Abstract Background Effect */}
  <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-primary opacity-20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-blue-900 opacity-20 rounded-full blur-3xl"></div>
</section>
