---
// ATTENZIONE: body è HTML generato da Phase 3 — mai iniettare contenuto da input utente (T-02-09)
import Layout from '../../layouts/Layout.astro';
import SchemaGraph from '../../components/SchemaGraph.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ContactForm from '../../components/ContactForm.astro';
import siteConfig from '../../data/site.config.json';
import { fetchAllPages, requirePage } from '../../lib/fetchPages';
import type { PageContent } from '../../lib/fetchPages';

export async function getStaticPaths() {
  const pages = await fetchAllPages();
  return siteConfig.zones.map(zone => ({
    params: { zone: String(zone) },
    props: { content: requirePage(pages, `zone/${zone}`) }
  }));
}

const { content } = Astro.props as { content: PageContent };
const { zone } = Astro.params;
const siteUrl = `https://${siteConfig.domain}`;

const breadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Zone', url: `${siteUrl}/zone/` },
  { name: zone, url: `${siteUrl}/zone/${zone}/` }
];
---

<Layout title={content.title} description={content.meta.description} canonical={`${siteUrl}/zone/${zone}/`}>
  <SchemaGraph
    slot="head"
    pageType="zone"
    zoneSlug={zone}
    breadcrumbs={breadcrumbs}
  />
  <main class="container mx-auto px-4 py-8 max-w-4xl">
    <Breadcrumb items={breadcrumbs} />
    <Fragment set:html={content.body} />
    <InternalLinks currentZone={zone} pageType="zone" />
    <ContactForm projectId={siteConfig.projectId} projectName={siteConfig.slug} />
  </main>
</Layout>
