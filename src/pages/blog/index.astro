---
import Layout from '../../layouts/Layout.astro';
import SchemaGraph from '../../components/SchemaGraph.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import siteConfig from '../../data/site.config.json';
import { fetchAllPages } from '../../lib/fetchPages';
import type { PageContent } from '../../lib/fetchPages';

const pages = await fetchAllPages();
const blogPages: PageContent[] = pages.filter(p => p.type === 'blog');
const siteUrl = `https://${siteConfig.domain}`;

// Blog index non richiede slug D1 specifico — usa i post filtrati
const breadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Blog', url: `${siteUrl}/blog/` }
];
---

<Layout
  title={`Blog — ${siteConfig.niche} ${siteConfig.city}`}
  description={`Articoli su ${siteConfig.niche.replace(/-/g, ' ')} a ${siteConfig.city} e provincia.`}
  canonical={`${siteUrl}/blog/`}
>
  <SchemaGraph
    slot="head"
    pageType="blog"
    breadcrumbs={breadcrumbs}
  />
  <main class="container mx-auto px-4 py-8 max-w-4xl">
    <Breadcrumb items={breadcrumbs} />
    <h1 class="text-3xl font-bold mb-6">Blog</h1>
    {blogPages.length === 0 && (
      <p class="text-gray-500">Articoli in arrivo.</p>
    )}
    <ul class="space-y-4">
      {blogPages.map(post => {
        const postSlug = post.slug.replace('blog/', '');
        return (
          <li>
            <a href={`/blog/${postSlug}/`} class="text-xl font-semibold text-blue-700 hover:underline">
              {post.title}
            </a>
            <p class="text-gray-600 mt-1">{post.meta.description}</p>
          </li>
        );
      })}
    </ul>
  </main>
</Layout>
