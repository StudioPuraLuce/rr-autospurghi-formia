---
// ATTENZIONE: body è HTML generato da Phase 3 — mai iniettare contenuto da input utente (T-02-09)
import Layout from '../../layouts/Layout.astro';
import SchemaGraph from '../../components/SchemaGraph.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ContactForm from '../../components/ContactForm.astro';
import siteConfig from '../../data/site.config.json';
import { fetchAllPages } from '../../lib/fetchPages';
import { buildServiceZonePaths } from '../../lib/buildPaths';
import type { PageContent } from '../../lib/fetchPages';

export async function getStaticPaths() {
  const pages = await fetchAllPages();
  return buildServiceZonePaths(siteConfig.services, siteConfig.zones, pages);
}

const { content } = Astro.props as { content: PageContent };
const { service, zone } = Astro.params;
const siteUrl = `https://${siteConfig.domain}`;

const breadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: service.replace(/-/g, ' '), url: `${siteUrl}/${service}/` },
  { name: zone, url: `${siteUrl}/${service}/${zone}/` }
];
---

<Layout
  title={content.title}
  description={content.meta.description}
  canonical={`${siteUrl}/${service}/${zone}/`}
>
  <SchemaGraph
    slot="head"
    pageType="service_zone"
    serviceSlug={service}
    zoneSlug={zone}
    faqs={content.faq}
    breadcrumbs={breadcrumbs}
  />
  <main class="container mx-auto px-4 py-8 max-w-4xl">
    <Breadcrumb items={breadcrumbs} />
    <Fragment set:html={content.body} />
    <InternalLinks currentService={service} currentZone={zone} pageType="service_zone" />
    <ContactForm projectId={siteConfig.projectId} projectName={siteConfig.slug} />
  </main>
</Layout>
